// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          Int        @id @default(autoincrement())
  productId   Int        @unique
  sortOrder   Int        @default(0)
  image       String?
  urlPreview  String?
  githubUrl   String?
  figmaUrl    String?
  internal    Boolean    @default(false)
  categories  Category[] @relation("ProjectCategories")
  skills      Skill[]    @relation("ProjectSkills")
  translations ProjectTranslation[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model ProjectTranslation {
  id          Int     @id @default(autoincrement())
  locale      String
  projectName String
  description String
  projectId   Int
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  projects Project[] @relation("ProjectCategories")
}

model Skill {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  projects Project[] @relation("ProjectSkills")
}

model Message {
  id        Int       @id @default(autoincrement())
  name      String
  email     String
  message   String
  read      Boolean   @default(false)
  repliedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model SiteContent {
  id        Int      @id @default(autoincrement())
  section   String   // e.g., "banner", "about", "skills", "contact", "navbar"
  key       String   // e.g., "greeting", "description", "email"
  locale    String   @default("") // "id", "en", or "" for non-localized
  value     String   // text or JSON for complex data
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([section, key, locale])
}
